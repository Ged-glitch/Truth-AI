{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/frontend/Truth-AI.dc",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/frontend/Truth-AI.dc.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
